{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/broomva/kanon/packages/core/schema/event.schema.json",
  "title": "Kanon Event v1",
  "description": "One attributed mutation in a Kanon workspace log. Events are append-only JSONL lines; the log is canonical and every store (SQLite, Postgres, UI) is a rebuildable projection. Language-neutral contract: Rust (Symphony/Lago) and TypeScript both read this.",
  "type": "object",
  "required": ["id", "ts", "workspace", "actor", "op", "model", "modelId", "data", "v"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID — total order after union merge"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of the mutation"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "description": "Workspace slug; one git data-repo per workspace"
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "surface"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["human", "agent", "app", "system"] },
        "id": { "type": "string", "minLength": 1 },
        "sessionId": { "type": "string", "minLength": 1 },
        "surface": { "enum": ["cli", "http", "mcp", "ui", "import", "system"] }
      }
    },
    "op": {
      "enum": ["create", "update", "archive", "unarchive", "delete", "relate", "unrelate"]
    },
    "model": {
      "enum": [
        "workspace",
        "team",
        "actor",
        "workflow_state",
        "issue",
        "label",
        "issue_relation",
        "project",
        "milestone",
        "initiative",
        "status_update",
        "document",
        "cycle",
        "comment",
        "agent_session",
        "agent_activity",
        "api_key",
        "webhook"
      ]
    },
    "modelId": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID entity key. Display identifiers (BRO-1234) are aliases, never keys"
    },
    "data": {
      "type": "object",
      "description": "Changed fields (op=update) or full initial state (op=create)"
    },
    "v": {
      "const": 1,
      "description": "Event schema version; bump with upcasters, never break"
    }
  }
}
