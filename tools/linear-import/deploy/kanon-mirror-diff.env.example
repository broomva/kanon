# kanon-mirror-diff.env — copy to /home/agent/kanon-mirror-diff.env, fill in
# the secrets, and `chmod 600`. Never commit the real file.
#
# Linear API token for the live pull (source of truth). SECRET.
LINEAR_API_KEY=lin_xxx_REPLACE_ME
# Bearer token the shadow REST accepts — the token BEFORE the first colon in the
# server's KANON_API_KEYS (see ~/kanon-live.env). SECRET.
KANON_API_KEY=REPLACE_ME
# Shadow REST base (optional; this is the default).
KANON_SERVER_URL=http://localhost:8793
