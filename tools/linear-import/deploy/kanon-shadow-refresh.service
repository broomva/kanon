# kanon-shadow-refresh.service — one Linear → Kanon shadow re-import.
# Timer-triggered (kanon-shadow-refresh.timer); installed by deploy/install.sh.
# Paths follow the agent@ VPS layout (mirrors kanon-live.service).
[Unit]
Description=Kanon shadow-mirror refresh (Linear -> Kanon re-import)
After=network-online.target kanon-live.service
Wants=network-online.target

[Service]
Type=oneshot
User=agent
EnvironmentFile=/home/agent/kanon-shadow-refresh.env
ExecStart=/home/agent/kanon/tools/linear-import/refresh.sh
Nice=10
# The importer paginates the whole workspace; give it room but never hang.
TimeoutStartSec=900
