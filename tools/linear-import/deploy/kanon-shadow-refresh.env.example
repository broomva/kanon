# kanon-shadow-refresh.env — copy to /home/agent/kanon-shadow-refresh.env,
# fill in LINEAR_API_KEY, and `chmod 600`. Never commit the real file.
#
# The shadow data repo the importer re-imports into (KANON_GIT_REMOTE_SYNC=0).
KANON_DATA_DIR=/home/agent/kanon-data-broomva-live
# Linear API token used for the live pull. SECRET — do not commit.
LINEAR_API_KEY=lin_xxx_REPLACE_ME
# kanon checkout that provides tools/linear-import (optional; inferred otherwise).
KANON_REPO=/home/agent/kanon
# bun binary (optional; falls back to PATH then ~/.bun/bin/bun).
BUN=/home/agent/.bun/bin/bun
# Optional durable JSON receipt per run, for the mirror-diff soak (BRO-1651).
KANON_REFRESH_LOG=/home/agent/kanon-shadow-refresh.jsonl
